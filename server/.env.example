# Backend (Express) — salin ke server/.env lalu isi.
# JANGAN commit server/.env (lihat .gitignore). Security PRD 3.5.

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key
# Service key HANYA di backend, JANGAN pernah di frontend.
SUPABASE_SERVICE_KEY=your_service_role_key

# Server
PORT=3001
NODE_ENV=development

# CORS allowlist (pisahkan dengan koma). Domain frontend.
CORS_ORIGINS=http://localhost:5173,http://localhost:5174
