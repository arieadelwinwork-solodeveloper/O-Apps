# Frontend (Vite) — salin ke .env lalu isi nilainya.
# Simpan sebagai UTF-8 (di Notepad: Save As → Encoding: UTF-8).
# JANGAN commit file .env (lihat .gitignore).
# Hanya boleh memakai ANON key di frontend, JANGAN service key (Security PRD 3.5).

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# URL backend Express (Fase A)
VITE_API_URL=http://localhost:3001

# Mode demo UI — data simulasi tanpa backend Node.js
# true  = selalu pakai mock (preview fitur)
# false = coba backend dulu; di dev otomatis fallback mock jika backend mati
VITE_USE_MOCK_API=true
